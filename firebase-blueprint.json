{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "A message sent from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name" },
        "email": { "type": "string", "format": "email", "description": "Sender's email" },
        "subject": { "type": "string", "description": "Message subject" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "SiteData": {
      "title": "Site Data",
      "description": "Global settings and information for the portfolio.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "github": { "type": "string" },
        "linkedin": { "type": "string" },
        "email": { "type": "string" },
        "resumeLink": { "type": "string" },
        "avatarUrl": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "tech": { "type": "array", "items": { "type": "string" } },
        "demoLink": { "type": "string" },
        "githubLink": { "type": "string" },
        "image": { "type": "string" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A technical skill.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "level": { "type": "number" },
        "icon": { "type": "string" }
      },
      "required": ["name", "category"]
    },
    "Experience": {
      "title": "Experience",
      "description": "Work experience entry.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "company": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "achievements": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["role", "company", "period"]
    },
    "Education": {
      "title": "Education",
      "description": "Education entry.",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "institution": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["degree", "institution"]
    },
    "Certification": {
      "title": "Certification",
      "description": "Professional certification.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "link": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "issuer"]
    },
    "Article": {
      "title": "Article",
      "description": "Blog post or article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "readTime": { "type": "string" },
        "image": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" }
      },
      "required": ["title", "date"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact messages."
    },
    "/settings/siteData": {
      "schema": "SiteData",
      "description": "Global site settings."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects."
    },
    "/skills/{skillId}": {
      "schema": "Skill",
      "description": "Technical skills."
    },
    "/experience/{experienceId}": {
      "schema": "Experience",
      "description": "Work experience."
    },
    "/education/{educationId}": {
      "schema": "Education",
      "description": "Education history."
    },
    "/certifications/{certificationId}": {
      "schema": "Certification",
      "description": "Certifications."
    },
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Blog articles."
    }
  }
}
